# CareConnect - Supabase Configuration
# All database operations now use Supabase (no local database needed)

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
DEBUG=True

# Secret Key (use a strong random string in production)
SECRET_KEY=your-super-secret-key-here-32-chars-minimum

# JWT Configuration
# JWT_SECRET should be a long random string, different from SECRET_KEY
JWT_SECRET=your-jwt-secret-key-here-minimum-32-chars
# Access token lifetime in hours (default 24)
JWT_ACCESS_EXPIRES_HOURS=24
# Refresh token lifetime in days (default 30)
JWT_REFRESH_EXPIRES_DAYS=30

# === SUPABASE Configuration (REQUIRED) ===
# Get these from https://supabase.com
# Steps:
#   1. Create a free account at https://supabase.com
#   2. Create a new project
#   3. Go to Project Settings → API
#   4. Copy the API URL and Anon/Public Key
#   5. Paste them below

# Your Supabase API URL (looks like https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Your Supabase Anon/Public Key (found in API settings)
SUPABASE_KEY=your-anon-public-key-here

# Optional: Service Role Key (for admin operations only)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase Storage Configuration
SUPABASE_STORAGE_BUCKET=careconnect-reports

# === Ollama Configuration (Local AI) ===
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3
OLLAMA_REQUEST_TIMEOUT_SEC=45
OLLAMA_NUM_CTX=1024
OLLAMA_NUM_PREDICT=220

## Notes:
# - DATABASE_URL, MONGODB_URI are DEPRECATED - use Supabase only
# - For development, use Supabase free tier (perfect for testing)
# - For production, consider Supabase professional tier
# - Keep SECRET_KEY and SUPABASE_KEY safe - never commit to git
# - All data now persists to Supabase cloud database
# - No local database setup needed
